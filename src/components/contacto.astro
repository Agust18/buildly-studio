<section class="contacto" id="contacto">
  <div class="container">
    <div class="contacto-inner">

      <div class="contacto-left reveal">
        <span class="section-tag">Contacto</span>

        <h2>¿Listo para<br/><span class="accent">empezar tu web?</span></h2>

        <p>
          Completá el formulario y te respondo en menos de 24 horas con una propuesta clara y sin compromiso.
        </p>

        <!-- 🔥 confianza -->
        <p class="contacto-extra">
          📩 Respuesta rápida · 💬 Sin compromiso · 🚀 Propuesta personalizada
        </p>

        <div class="contacto-datos">
          <a href="https://wa.me/542352506499?text=Hola%2C%20quiero%20mi%20web%21" target="_blank" class="contacto-dato">
            <span class="contacto-dato-icon">💬</span>
            <div>
              <div class="contacto-dato-label">WhatsApp</div>
              <div class="contacto-dato-value">Respuesta inmediata</div>
            </div>
          </a>

          <div class="contacto-dato">
            <span class="contacto-dato-icon">📍</span>
            <div>
              <div class="contacto-dato-label">Ubicación</div>
              <div class="contacto-dato-value">Buenos Aires, Argentina</div>
            </div>
          </div>
        </div>
      </div>

      <form class="reveal reveal-delay-1" action="https://formspree.io/f/mrbawopg" method="POST">

        <div class="form-group">
          <label>Nombre</label>
          <input type="text" name="nombre" placeholder="Tu nombre" required />
        </div>

        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="tu@email.com" required />
        </div>

        <div class="form-group">
          <label>Servicio de interés</label>
          <select name="servicio">
            <option value="" disabled selected>Seleccioná un servicio</option>
            <option value="landing">Landing Page</option>
            <option value="institucional">Web Institucional</option>
            <option value="catalogo">Catálogo Online</option>
            <option value="evento">Web para Eventos</option>
            <option value="portfolio">Portafolio</option>
            <option value="menu">Menú Digital</option>
            <option value="otro">No estoy seguro</option>
          </select>
        </div>

        <div class="form-group">
          <label>Contame tu proyecto</label>
          <textarea name="message" placeholder="¿Qué necesitás? ¿Tenés fecha o presupuesto estimado?" required></textarea>
        </div>

        <!-- 🔥 refuerzo de confianza -->
        <p class="form-note">
          Te voy a responder con una propuesta clara y adaptada a lo que necesitás.
        </p>

        <button type="submit" class="btn-submit">
          Solicitar presupuesto →
        </button>

      </form>

    </div>
  </div>
</section>