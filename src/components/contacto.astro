<section class="contacto" id="contacto">
  <div class="container">
    <div class="contacto-inner">

      <div class="contacto-left reveal">
        <span class="section-tag">Contacto</span>
        <h2>¿Listo para<br/><span class="accent">empezar tu web?</span></h2>
        <p>Completá el formulario y te respondo en menos de 24 horas con una propuesta clara y sin compromiso.</p>

        <p class="contacto-extra">
          📩 Respuesta rápida · 💬 Sin compromiso · 🚀 Propuesta personalizada
        </p>

        <div class="contacto-datos">
          <a href="https://wa.me/542352506499?text=Hola%2C%20quiero%20mi%20web%21" 
             target="_blank" 
             class="contacto-dato"
             aria-label="Contactar por WhatsApp para respuesta inmediata">
            <span class="contacto-dato-icon">💬</span>
            <div>
              <div class="contacto-dato-label">WhatsApp</div>
              <div class="contacto-dato-value">Respuesta inmediata</div>
            </div>
          </a>

          <div class="contacto-dato">
            <span class="contacto-dato-icon">📍</span>
            <div>
              <div class="contacto-dato-label">Ubicación</div>
              <div class="contacto-dato-value">Buenos Aires, Argentina</div>
            </div>
          </div>
        </div>
      </div>

      <form class="reveal reveal-delay-1" action="https://formspree.io/f/mrbawopg" method="POST">
        
        <div class="form-group">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" required />
        </div>

        <div class="form-group">
          <label for="servicio-select">Servicio de interés</label> 
          <select name="servicio" id="servicio-select" required> 
            <option value="" disabled selected>Seleccioná un servicio</option>
            <option value="Landing Page">Landing Page</option>
            <option value="Web Institucional">Web Institucional</option>
            <option value="Catalogo Online">Catálogo Online</option>
            <option value="Web Eventos">Web para Eventos</option>
            <option value="Portfolio Web">Portafolio Web</option>
            <option value="Menu Digital">Menú Digital</option>
            <option value="Otro">No estoy seguro</option>
          </select>
        </div>

        <div class="form-group">
          <label for="mensaje">Contame tu proyecto</label>
          <textarea id="mensaje" name="message" placeholder="¿Qué necesitás? ¿Tenés fecha o presupuesto estimado?"></textarea>
        </div>

        <p class="form-note">
          Te voy a responder con una propuesta clara y adaptada a lo que necesitás.
        </p>

        <button type="submit" class="btn-submit">
          Solicitar presupuesto →
        </button>

      </form>

    </div>
  </div>
</section>